# =============================================================================
# Workbench Connector for GCP — local secrets for publishing & signing.
#
# Copy this file to `secrets.properties` (next to it) and fill in the values.
# `secrets.properties` is gitignored so it never leaves your machine.
#
# Both build lines (2025.3 and 2026.1) look up the same file:
#   1. <line root>/secrets.properties        (e.g. ./pycharm-plugin-2026.1/secrets.properties)
#   2. <parent dir>/secrets.properties       (this file at the repo root — recommended)
#   3. Environment variable with the same name
# The first hit wins. If nothing is set, `publishPlugin` / `signPlugin` fail
# with a clear "no value provided" error and `buildPlugin` keeps working.
# =============================================================================

# --- JetBrains Marketplace --------------------------------------------------
# Permanent token from https://plugins.jetbrains.com/author/me/tokens
# Required by `./gradlew publishPlugin`.
JETBRAINS_MARKETPLACE_TOKEN=perm_REPLACE_ME

# --- Optional plugin signing ------------------------------------------------
# See https://plugins.jetbrains.com/docs/intellij/plugin-signing.html for the
# `openssl` recipe that generates these three values from a self-signed key.
# All three are required together; if any is missing, signing is skipped.

# Full PEM certificate chain (you can paste a multi-line PEM as a single line
# using \n escapes, or just leave the value on one line if your tooling
# already inlined the PEM).
JETBRAINS_CERTIFICATE_CHAIN=

# PEM-encoded private key matching the certificate.
JETBRAINS_PRIVATE_KEY=

# Password for the private key (empty string if the key has no password).
JETBRAINS_PRIVATE_KEY_PASSWORD=
